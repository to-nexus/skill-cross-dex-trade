# cross-dex-trade — copy to .env and fill in. NEVER COMMIT THIS FILE.

# REQUIRED — EOA private key that signs swaps and liquidity txs. 0x-prefixed, 64 hex chars.
PRIVATE_KEY=0x

# OPTIONAL — defaults shown. Override only if you have a private CROSS RPC.
# CROSS_RPC_URL=https://mainnet.crosstoken.io:22001/

# OPTIONAL — declared address of the EOA. If set, the script warns when
# this doesn't match the address derived from PRIVATE_KEY.
# WALLET_ADDRESS=0x

# OPTIONAL but RECOMMENDED — hard cap on per-transaction CROSS notional.
# buy: CROSS spend, buy-exact: max CROSS input, sell: quoted CROSS output,
# deposit: CROSS input, withdraw: quoted CROSS output.
MAX_TRADE_CROSS=10

# OPTIONAL — defaults to the production GameToken swap API.
# GAME_SWAP_API_URL=https://game-swap-api.cross.nexus/v1

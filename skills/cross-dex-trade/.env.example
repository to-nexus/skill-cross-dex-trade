# cross-dex-trade — copy to .env and fill in. NEVER COMMIT THIS FILE.

# REQUIRED — EOA private key that signs trades. 0x-prefixed, 64 hex chars.
PRIVATE_KEY=0x

# OPTIONAL — defaults shown. Override only if you have a private CROSS RPC.
# CROSS_RPC_URL=https://mainnet.crosstoken.io:22001/

# OPTIONAL — declared address of the EOA. If set, the script warns when
# this doesn't match the address derived from PRIVATE_KEY.
# WALLET_ADDRESS=0x

# OPTIONAL but RECOMMENDED — hard cap on per-trade CROSS notional.
# Aborts the trade if (price * amount) exceeds this many CROSS.
MAX_TRADE_CROSS=10
